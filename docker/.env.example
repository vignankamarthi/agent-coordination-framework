# MySQL Database Configuration
MYSQL_HOST=mysql
MYSQL_DATABASE=IMPEL_courses
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
MYSQL_POOL_SIZE=5

# Neo4j Database Configuration
# NOTE: Contact repository creators for Neo4j credentials if you need access to the full dataset
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CONTACT_CREATORS_FOR_CREDENTIALS  # Get credentials from repository creators
NEO4J_DATABASE=neo4j  # Default database name, verify with your Neo4j instance

# API Keys (Replace with your actual keys)
COHERE_API_KEY=your-cohere-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here
OPENAI_API_KEY=your-openai-api-key-here # For LangSmith integration

# LangSmith Configuration - MANDATORY for system observability
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=IMPEL

# Model Configuration (Optional - defaults provided)
COHERE_EMBED_MODEL=embed-english-v3.0
COHERE_GENERATE_MODEL=command-r-08-2024
COHERE_CHAT_MODEL=command-r
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Application Settings
LOG_LEVEL=INFO
DEBUG=false